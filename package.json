{
  "name": "daily-journal-opener",
  "publisher": "palani",
  "displayName": "Daily Journal Opener",
  "description": "Open or create today's journal note in a YYYY-MM/YYYY-MM-DD.md structure.",
  "license": "MIT",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "journal",
    "daily-notes",
    "markdown",
    "productivity"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/palamccc/daily-journal-opener.git"
  },
  "homepage": "https://github.com/palamccc/daily-journal-opener#readme",
  "bugs": {
    "url": "https://github.com/palamccc/daily-journal-opener/issues"
  },
  "activationEvents": [
    "onCommand:daily-journal-opener.openToday"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "daily-journal-opener.openToday",
        "title": "Daily Journal: Open Today's Note"
      }
    ],
    "keybindings": [
      {
        "command": "daily-journal-opener.openToday",
        "key": "ctrl+f9",
        "mac": "cmd+f9"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "build-vsix": "npx @vscode/vsce package",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.115.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
